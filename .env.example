# ==============================================================================
# Anthropic API
# ==============================================================================
# Generar key en: https://console.anthropic.com/settings/keys
# NUNCA commitear el .env real con la key.
ANTHROPIC_API_KEY=sk-ant-api03-***

# Modelo de LLM. Default: claude-haiku-4-5 (rapido, barato, structured outputs).
# Alternativos:
#   - claude-sonnet-4-5-20251022 (mas capaz, mas caro)
#   - claude-opus-4-5            (top capability, mas caro)
MODEL_NAME=claude-haiku-4-5-20251001


# ==============================================================================
# Caps operacionales (anti-runaway)
# ==============================================================================
# Maximo numero de acciones que el PaymentNavigator puede tomar antes de
# rendirse. Cada accion = 1 LLM call. Cap defensivo contra loops infinitos.
MAX_NAVIGATOR_STEPS=6

# Timeout total por request (en segundos). Despues de esto se devuelve TIMEOUT.
REQUEST_TIMEOUT_S=60

# Timeout especifico de Playwright para esperar selectors (en milisegundos).
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=15000


# ==============================================================================
# Logging
# ==============================================================================
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Formato de logs: 'json' (production) | 'console' (development)
LOG_FORMAT=console


# ==============================================================================
# Server
# ==============================================================================
HOST=0.0.0.0
PORT=8000


# ==============================================================================
# Debug flags
# ==============================================================================
# Si True, el FalabellaAdapter dumpea el DOM capturado del checkout a /tmp/
# para inspeccion offline. Util para debuggear el _navigate_to_checkout.
# Default: False (no dump en produccion).
DUMP_FALABELLA_DOM=false


# ==============================================================================
# Modelo de LLM alternativo (Ollama, swap local)
# ==============================================================================
# Para correr sin Anthropic API, descomentar y apuntar a un servidor Ollama
# local con un modelo capaz de structured outputs (e.g. qwen2.5:7b-instruct).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b-instruct
